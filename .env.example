# =============================================
# KRUZBERG CRM - Environment Variables
# =============================================

# Supabase Configuration
# Get these from: https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Email — OVH SMTP (envoi)
SMTP_HOST=ssl0.ovh.net
SMTP_PORT=587
SMTP_USER=booking@kruzberg.com
SMTP_PASSWORD=your-email-password-here

# Email — OVH IMAP (réception / sync)
IMAP_HOST=ssl0.ovh.net
IMAP_PORT=993
IMAP_USER=booking@kruzberg.com
IMAP_PASSWORD=your-email-password-here

# Cron secret (protection de la route sync)
CRON_SECRET=your-random-secret-here
